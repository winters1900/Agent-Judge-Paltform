APP_NAME=AI Coding Agent Evaluation Platform
ENVIRONMENT=development

# 生产用 MySQL；本地/演示可改用 sqlite（无需额外服务）：
# DATABASE_URL=sqlite:///./eval_platform.db
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/eval_platform
REDIS_URL=redis://localhost:6379/0

# ── LLM 接入（OpenAI 兼容）：被测 Agent 调用 + LLM-as-a-Judge 共用 ──
# 不配置 LLM_API_KEY 时，LLM-Judge 指标会被自动跳过（仍可跑显式指标 + mock 适配器）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=60

# ── 评测执行 ──
EVAL_CONCURRENCY=1
EVAL_SEED_DEFAULTS=true
