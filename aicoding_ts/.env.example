# 通用 LLM 配置（适用于 LiteLLM、OpenAI、DeepSeek、豆包等 OpenAI-compatible provider）
LLM_API_KEY=your_api_key_here
LLM_MODEL=your_model_name_here

# OpenAI-compatible 端点 base URL
# LiteLLM proxy: http://localhost:4000
# OpenAI:        https://api.openai.com/v1  （不填时默认此值）
# 豆包:          https://ark.cn-beijing.volces.com/api/v3
LLM_BASE_URL=https://api.openai.com/v1

# 可选：provider 标识，设为 "doubao" 时自动注入 thinking/reasoning_effort 参数
# LLM_PROVIDER=doubao

# 可选：模型调用参数（不填使用内置默认值）
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=2048
# LLM_TOP_P=0.9
# LLM_TIMEOUT=60000
# LLM_MAX_RETRIES=2

# 向后兼容别名（LLM_* 未设置时仍生效，无需迁移现有配置）
# DOUBAO_API_KEY=your_doubao_api_key_here
# DOUBAO_MODEL=your_doubao_model_name_here
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 可选：指定 Agent 操作的工作区目录（绝对路径），不填时使用默认的 workspaces/demo-project/workspace/
# WORKSPACE_DIR=/path/to/your/project
