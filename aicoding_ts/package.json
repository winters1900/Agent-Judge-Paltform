{
  "name": "ai-coding-agent-web-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --experimental-strip-types server.ts",
    "start": "node --experimental-strip-types server.ts",
    "build:web": "tsc -p apps/web/tsconfig.build.json",
    "dev:web": "tsc -w -p apps/web/tsconfig.build.json",
